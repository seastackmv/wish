{
	"name": "wish",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"description": "Anonymous civic platform to surface the problems and wishes that matter - for a better Maldives.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/seastackmv/wish.git"
	},
	"author": "Seastack",
	"homepage": "https://wish.seastack.mv",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:migrations": "wrangler d1 migrations list wish-db --remote",
		"db:migrate": "wrangler d1 migrations apply wish-db --remote",
		"db:migrate:local": "wrangler d1 migrations apply wish-db --local"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260511.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22.0.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"wrangler": "4.90.1"
	},
	"dependencies": {
		"arctic": "^3.7.0",
		"gsap": "^3.15.0",
		"lenis": "^1.3.25"
	}
}
